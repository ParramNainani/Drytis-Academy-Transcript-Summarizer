# Copy this file to .env and fill in your own values. Never commit the real .env file.

# Required: your free Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-key-here

# Optional: override the default model
SUMMARY_MODEL=gemini-1.5-flash

# Optional: restrict CORS to your deployed frontend origin instead of "*"
ALLOWED_ORIGINS=*
